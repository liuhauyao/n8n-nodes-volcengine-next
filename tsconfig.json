{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"lib": ["ES2022"],
		"outDir": "dist",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": false,
		"sourceMap": true,
		"resolveJsonModule": true,
		"moduleResolution": "node",
		"types": ["node"],
		"baseUrl": ".",
		"paths": {
			"n8n-workflow": ["./node_modules/n8n-workflow/dist/cjs/index.d.ts"]
		}
	},
	"include": ["credentials/**/*.ts", "nodes/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
